# Supabase (recommended — replaces raw PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# MySQL 8 (dashboard + scraper; migrations run in scraper container)
DATABASE_URL=mysql://root:postgres@localhost:3307/campaigns
DATABASE_URL_SCRAPER=mysql://root:postgres@localhost:3307/campaigns

# AI / DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat
# BE-10: AI analysis batch processing.
# AI_BATCH_SIZE = how many campaigns are bundled into a single AI call inside
#                 ai-analysis-batch. A failed sub-batch does not abort the job
#                 (successful sub-batches still persist). Set to 1 to disable
#                 batching and fall back to one campaign per AI call.
# AI_COLLECTOR_BATCH_SIZE = how many freshly-scraped campaigns the scraper
#                           accumulates before flushing them to a single
#                           ai-analysis-batch job. Independent from
#                           AI_BATCH_SIZE; the job processor still chunks the
#                           payload into AI_BATCH_SIZE-sized AI calls.
AI_BATCH_SIZE=5
AI_COLLECTOR_BATCH_SIZE=20

# SSE / Events (in-memory)
# SSE uses in-memory storage, not Redis pub/sub

# Scraping
SCRAPER_CONCURRENCY=3
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_TIMEOUT_MS=30000
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; BitalihBot/1.0)

# 4nala
FOURNALA_BASE_URL=https://www.4nala.com
FOURNALA_API_KEY=

# Altiliganyan
ALTILIGANYAN_BASE_URL=https://www.altiliganyan.com

# Atyarisi
ATYARISI_BASE_URL=https://www.atyarisi.com

# Bilyoner
BILYONER_BASE_URL=https://www.bilyoner.com
BILYONER_API_KEY=

# Birebin
BIREBIN_BASE_URL=https://www.birebin.com
BIREBIN_API_KEY=

# Ekuri
EKURI_BASE_URL=https://www.ekuri.com

# Hipodrom
HIPODROM_BASE_URL=https://www.hipodrom.com

# Misli
MISLI_BASE_URL=https://www.misli.com
MISLI_API_KEY=

# Nesine
NESINE_BASE_URL=https://www.nesine.com
NESINE_API_KEY=

# Oley
OLEY_BASE_URL=https://www.oley.com

# Sundzulyuk
SUNDZULYUK_BASE_URL=https://www.sundzulyuk.com

# Dashboard (Vercel)
NEXT_PUBLIC_API_URL=https://your-project.vercel.app/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin
ADMIN_API_KEY=your-admin-api-key-here

# CORS allowed origins (comma-separated). Boş bırakılırsa dev'de * fallback,
# production'da CORS header gönderilmez (browser reddeder).
# Örnek: https://rakipanaliz.example.com,https://app.example.com
ALLOWED_ORIGINS=

# Log level
LOG_LEVEL=info
