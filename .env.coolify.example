# Database (MySQL 8)
MYSQL_ROOT_PASSWORD=your_secure_password_here
MYSQL_DATABASE=campaigns
DATABASE_URL=mysql://root:your_secure_password_here@db:3306/campaigns

# Dashboard
NEXT_PUBLIC_API_URL=
ADMIN_API_KEY=change_me_to_a_strong_random_value

# DeepSeek AI
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Scraper Settings
SSE_HEARTBEAT_MS=15000
AI_JOB_POLL_MS=5000
LOG_LEVEL=info
SCRAPER_CONCURRENCY=2
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=45000
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_EXPAND_MAX_CLICKS=20
SCRAPER_EXPAND_WAIT_MS=1200

# Optional: override migrations path (defaults to /app/db/migrations in container)
# DB_MIGRATIONS_PATH=/app/db/migrations
