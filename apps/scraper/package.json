{
  "name": "@bitalih/scraper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --format=esm --packages=external",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "scrape": "tsx src/cli.ts",
    "clean": "rm -rf dist",
    "test": "tsx --test",
    "test:smoke": "tsx src/test/smoke-test.ts"
  },
  "dependencies": {
    "@bitalih/shared": "workspace:*",
    "axios": "^1.6.7",
    "cheerio": "^1.0.0-rc.12",
    "cron": "^3.1.6",
    "dotenv": "^16.4.5",
    "mysql2": "^3.11.5",
    "playwright": "^1.42.0",
    "puppeteer": "^22.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0"
  }
}
